{
  "name": "@nuvo-ui/ui",
  "version": "0.1.0",
  "description": "Componentes UI para dashboards — copy-paste via CLI",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
